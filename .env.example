# N-central MCP Server — configuration template.
# Copy to `.env` and fill in the required values.

# ============================================================================
# REQUIRED
# ============================================================================

# Your N-central server URL (no trailing slash).
NC_SERVER_URL=https://ncentral.example.com

# User-API JWT token. Generate it in N-central UI:
#   Administration → User Management → Users → [user] → API Access → Generate JSON Web Token
# Best practice: use a dedicated API-only user with least-privilege roles.
# Note: the underlying API user password rotates every 90 days — regenerate the JWT proactively.
NC_JWT_TOKEN=your-jwt-token-here

# ============================================================================
# WRITE MODE (controls which tools are exposed)
# ============================================================================
# read-only — only GET endpoints
# write     — adds create/update tools (POST/PUT/PATCH)  [default]
# full      — adds destructive tools (delete_device, delete_maintenance_windows,
#             clear_device_notes, create_direct_scheduled_task, etc.)
NC_WRITE_MODE=write

# ============================================================================
# HTTP TRANSPORT — only needed when running as a Streamable HTTP server
# ============================================================================
# Set MCP_PORT to enable HTTP mode (stdio mode runs when MCP_PORT is unset).
MCP_PORT=3100

# REQUIRED when MCP_PORT is set. Generate with: openssl rand -hex 32
# Clients must send: Authorization: Bearer <key>
MCP_API_KEY=

# Bind address. Use 127.0.0.1 for localhost-only; 0.0.0.0 for Docker / LAN exposure.
MCP_BIND_ADDRESS=127.0.0.1

# Set to 1 to explicitly opt-out of the "API key required for HTTP" check (local dev only).
# MCP_ALLOW_UNAUTHENTICATED=0

# Comma-separated list of allowed CORS origins (e.g. http://localhost:3000,https://app.example.com).
# Leave empty to disable CORS entirely.
MCP_CORS_ORIGIN=

# Set to 1 if this server runs behind a trusted reverse proxy that sets X-Forwarded-For.
# Defaults to 0 — the header is otherwise spoofable.
MCP_TRUST_PROXY=0

# Require Bearer auth on /metrics (default: open access for scraping).
# MCP_METRICS_REQUIRE_AUTH=0

# ============================================================================
# HTTP TUNABLES (optional — sensible defaults shown)
# ============================================================================
# MCP_PORT default: 3100 (see above)
# MCP_MAX_BODY_SIZE=1048576           # 1 MB per request
# MCP_RATE_LIMIT_MAX=120              # requests per window
# MCP_RATE_LIMIT_WINDOW_MS=60000      # rate-limit window (ms)
# MCP_MAX_SESSIONS=256                # concurrent session cap
# MCP_SESSION_TTL_MS=1800000          # 30 min idle session timeout
# MCP_AUDIT_LEVEL=sensitive           # off | sensitive | all
# MCP_QUIET=0                         # 1 to suppress startup banner in stdio mode

# ============================================================================
# N-CENTRAL API TUNABLES (optional)
# ============================================================================
# NC_REQUEST_TIMEOUT_MS=30000         # per-request timeout
# NC_MAX_RETRIES=3                    # retries on 429 / 5xx / timeout
# NC_RETRY_DELAY_MS=2000              # base backoff (doubles per attempt)
# NC_RESOURCE_CACHE_TTL_MS=60000      # MCP resource cache TTL (0 to disable)

# Per-request override headers — see N-central API FAQs.
# Format: "<number><s|m|h>" (e.g. 30m, 4h, 120s). Shorter only — longer expiry is rejected.
# NC_ACCESS_EXPIRY=30m                # default access token lifetime: 60min
# NC_REFRESH_EXPIRY=4h                # default refresh token lifetime: 25h
